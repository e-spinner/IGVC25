<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">


    <!-- CHASSIS -->

    <!-- joint defining the translation in space between the base link and the center of the chassis link -->
    <joint name="chassis_joint" type="fixed">
        <!-- like a tree diagram each componet can only have one parent, but can have multiple children -->
        <parent link="base_link" />         
        <child link="chassis_link" />
        <!-- this is the positional ofset defined in meters through space along xyz and radians along rpy -->
        <origin xyz="-0.2794 0 0.13688" />   <!-- The z axis offset is alligned to the bottom of the chassis not the center of the wheel, UPDATED-->   
    </joint>

    <link name="chassis_link"> 
        <visual>
            <!-- The origin should be the center of mass, this is the reference point for joints -->
            <origin xyz="0 0 0" /> 
            <geometry>
                <box size="0.9144 0.6096 0.1524" />
            </geometry>
            <material name="white" />
        </visual>
        <collision>
            <origin xyz="0 0 0" /> 
            <geometry>
                <box size="0.9144 0.6096 0.1524" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="13.6" x="0.9144" y="0.6096" z="0.1524">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis_link">
        <material>Gazebo/White</material>
    </gazebo>





    <!-- MAIN DRIVE WHEELS -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel" />
        <origin xyz="0 0.349725 0" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.15875" length="0.06985" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.15875" length="0.06985" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="1" radius="0.15875" length="0.06985">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>





    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel" />
        <origin xyz="0 -0.349725 0" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.15875" length="0.06985" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <origin xyz="0 0 0" />
            <geometry>
                <cylinder radius="0.15875" length="0.06985" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="1" radius="0.15875" length="0.06985">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>





    <!-- CASTER WHEEL -->

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_wheel_link" />
        <origin xyz="-0.57275349 0 0" />
    </joint>

    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="0.15875" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.15875" />
            </geometry>
            <material name="blue" />
        </collision>
        <xacro:inertial_sphere mass="2" radius="0.15875">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_link">
        <material>Gazebo/Blue</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>

</robot>