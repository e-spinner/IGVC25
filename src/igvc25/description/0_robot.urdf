<!-- This is the core URDF (Universal Robot Description Format) file that defines the robot 
     for Ros2, Rviz2, and Gazebo-Classic
     It uses XACRO to break the single xml file into smaller more editable chunks -->
<robot name="robot">
  <!-- Origin of the robot in space - should be at pivot point
         basically a xyz origin reference with no shape or size -->
  <link name="base_link"/>
  <!-- Projection of base_link onto ground -->
  <link name="base_footprint"/>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 1 1"/>
  </material>
  <material name="orange">
    <color rgba="1 0.3 0.1 1"/>
  </material>
  <!-- Specify some standard inertial calculations https://en.wikipedia.org/wiki/List_of_moments_of_inertia -->
  <!-- These make use of xacro's mathematical functionality -->
  <joint name="footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <!-- difference in pos of base link and footprint -->
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -1.0"/>
  </joint>
  <link name="test_link">
    <visual name="">
      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="1.0 1.0 1.0"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="test_joint" type="fixed">
    <parent link="base_link"/>
    <child link="test_link"/>
    <origin xyz="-1.0 0.0 0.0"/>
  </joint>
</robot>
